{
  "ConnectionStrings": {
    "Default": "Host=localhost;Database=mediamanager;Username=postgres;Password={{POSTGRES_PASSWORD}}"
  },
  "Storage": {
    "Endpoint": "http://localhost:9000",
    "AccessKey": "{{MINIO_ACCESS_KEY}}",
    "SecretKey": "{{MINIO_SECRET_KEY}}",
    "BucketName": "media"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
